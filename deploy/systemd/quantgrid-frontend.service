[Unit]
Description=QuantGrid frontend
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/QuantGrid/frontend
Environment=VITE_API_URL=http://chandudevopai.shop:8000
ExecStart=/usr/bin/npm run dev -- --host 0.0.0.0 --port 5173
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
