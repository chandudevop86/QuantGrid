[Unit]
Description=QuantGrid frontend
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/QuantGrid/frontend
Environment=VITE_API_URL=/api
Environment=VITE_WS_URL=wss://chandudevopai.shop/ws
ExecStart=/usr/bin/npm run preview -- --host 127.0.0.1 --port 5173
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
