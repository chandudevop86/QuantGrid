# Local full-system Docker Compose defaults.
# Copy to .env to override values locally. Do not commit real secrets in .env.

QUANTGRID_ENV=local
QUANTGRID_AUTH_SECRET=local-dev-auth-secret-at-least-32-characters
QUANTGRID_ALLOW_DEV_SEED_USERS=true
QUANTGRID_USERS=admin:AdminPass1!:admin

POSTGRES_USER=quant
POSTGRES_PASSWORD=local-quantgrid-postgres
POSTGRES_DB=quantgrid
DATABASE_URL=postgresql+psycopg://quant:local-quantgrid-postgres@postgres:5432/quantgrid

REDIS_URL=redis://redis:6379/0
QUANTGRID_MARKET_DATA_PROVIDER=yahoo
QUANTGRID_ENABLE_LIVE_TRADING=false
ALLOW_SAMPLE_MARKET_DATA=true

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
