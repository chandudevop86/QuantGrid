{
  "name": "quantgrid-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "tsc --noEmit --pretty false",
    "type-check": "tsc -b --pretty false",
    "test": "vitest run",
    "test:a11y": "vitest run src/components/MarketStatusBanner.a11y.test.tsx src/pages/PublicAccess.a11y.test.tsx",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.7.9",
    "lightweight-charts": "^5.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^24.1.3",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0"
  }
}
