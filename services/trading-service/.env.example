# Copy this file to .env on the server and fill real secrets there.
# The backend loads services/trading-service/.env automatically.

QUANTGRID_ENV=local
QUANTGRID_ALLOW_DEV_SEED_USERS=true
QUANTGRID_AUTH_SECRET=replace-with-a-stable-secret-at-least-32-characters
QUANTGRID_USERS=admin:AdminPass1!:admin

DATABASE_URL=sqlite:///./Backend/data/quantgrid.sqlite3
JOB_STORE_DB_FILE=./data/dashboard_jobs.sqlite3
MARKET_DATA_DB_FILE=./Backend/data/market_data.sqlite3

QUANTGRID_MARKET_DATA_PROVIDER=yahoo
QUANTGRID_ENABLE_LIVE_TRADING=false
ALLOW_SAMPLE_MARKET_DATA=false

CORS_ALLOWED_ORIGINS=http://chandudevopai.shop:5173,http://chandudevopai.shop

# Optional alerts. Leave blank to disable a channel.
QUANTGRID_ALERTS_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
