# Copy this file to .env on a production server and fill real secrets.
# Do not commit the real .env file.

QUANTGRID_ENV=production
QUANTGRID_AUTH_SECRET=replace-with-a-stable-secret-at-least-32-characters
LOG_LEVEL=INFO
QUANTGRID_FORCE_HTTPS=true
QUANTGRID_ALLOW_ANONYMOUS_WEBSOCKET=false

# Production must use Postgres. Replace password/host/db for your deployment.
DATABASE_URL=postgresql+psycopg://quant:replace-with-postgres-password@127.0.0.1:5432/quantgrid

# Local seed users are disabled outside local mode.
QUANTGRID_ALLOW_DEV_SEED_USERS=false
QUANTGRID_USERS=

JOB_STORE_DB_FILE=./data/dashboard_jobs.sqlite3
MARKET_DATA_DB_FILE=./Backend/data/market_data.sqlite3

QUANTGRID_MARKET_DATA_PROVIDER=dhan
QUANTGRID_ALLOW_YAHOO_LIVE=false
KITE_API_KEY=
KITE_ACCESS_TOKEN=
UPSTOX_ACCESS_TOKEN=
FYERS_CLIENT_ID=
FYERS_ACCESS_TOKEN=
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_ACCESS_TOKEN=
QUANTGRID_ENABLE_LIVE_TRADING=false
BROKER_LIVE_ENABLED=false
QUANTGRID_ALLOW_APP_MANAGED_STOPS=false
QUANTGRID_EXIT_MONITOR_ENABLED=false
QUANTGRID_EXIT_MONITOR_MODE=live
QUANTGRID_EXIT_MONITOR_INTERVAL_SECONDS=5
QUANTGRID_BROKER_PROVIDER=dhan
QUANTGRID_BROKER_CLIENT_ID=1103636942
QUANTGRID_BROKER_ACCESS_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzUxMiJ9.eyJpc3MiOiJkaGFuIiwicGFydG5lcklkIjoiIiwiZXhwIjoxNzg0NDUwNTQ3LCJpYXQiOjE3ODQzNjQxNDcsInRva2VuQ29uc3VtZXJUeXBlIjoiU0VMRiIsIndlYmhvb2tVcmwiOiIiLCJkaGFuQ2xpZW50SWQiOiIxMTAzNjM2OTQyIn0.PLrjjzDekqXYN1Y5AfUnZ0k9lhhdfTe0eySUQ_0f1IAbb45oWbCS67-Hdv0IOhEFXVE7ZChM_WaHHW_-89m5oA
DHAN_MARKET_EXCHANGE_SEGMENT=IDX_I
DHAN_INSTRUMENT_TYPE=INDEX
QUANTGRID_DEFAULT_LOT_SIZE=1
QUANTGRID_LOT_SIZE_NIFTY=65
QUANTGRID_MAX_ORDER_NOTIONAL=1000000
QUANTGRID_MARGIN_MULTIPLIER=1
QUANTGRID_ROUND_DOWN_TO_LOT=true
MIN_SIGNAL_SCORE=7
SIGNAL_MAX_AGE_MINUTES=2
QUANTGRID_CANDLE_WARNING_SECONDS=120
QUANTGRID_CANDLE_REJECT_SECONDS=300
QUANTGRID_FEED_DELAY_TOLERANCE_SECONDS=60
QUANTGRID_MAX_MISSING_CANDLES=2
QUANTGRID_NSE_HOLIDAYS=2026-01-26,2026-03-03,2026-03-31,2026-04-03,2026-04-14,2026-05-01,2026-08-15,2026-10-02,2026-11-09,2026-12-25
QUANTGRID_MARKET_CACHE_TTL_SECONDS=5
QUANTGRID_OPTION_CHAIN_CACHE_SECONDS=60
QUANTGRID_DHAN_429_COOLDOWN_SECONDS=300
# Backend and worker run as host systemd services in this deployment.
REDIS_URL=redis://127.0.0.1:6379/0
QUANTGRID_REDIS_RECONNECT_SECONDS=10
QUANTGRID_MAX_DAILY_LOSS=3000
QUANTGRID_MAX_TRADES_PER_DAY=3
QUANTGRID_MAX_CONSECUTIVE_LOSSES=2

# Institutional dashboard inputs. Populate from your licensed/current data source.
FII_CASH_FLOW=
DII_CASH_FLOW=
FII_INDEX_FUTURES=
GIFT_NIFTY=
INDIA_VIX=
USDINR=
CRUDE_OIL=
