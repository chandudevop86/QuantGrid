--- services/trading-service/Backend/domain/risk/risk_manager.py
+++ services/trading-service/Backend/domain/risk/risk_manager.py
@@ -4,11 +4,27 @@
 
 from Backend.domain.models.signal import StrategySignal
 
+# Hard safety cap on risk-per-trade, independent of whatever risk_pct is passed in. This is a
+# defense-in-depth guard: if a caller passes a value that's wrong by 100x (see risk_fraction
+# below) or simply fat-fingers e.g. risk_pct=25 thinking it means 0.25%, this stops a single
+# trade from risking an unreasonable fraction of capital regardless of the input.
+MAX_RISK_FRACTION_PER_TRADE = 0.10  # 10% of capital, absolute ceiling
+
 
 class RiskManager:
     def risk_fraction(self, risk_pct: float) -> float:
-        value = float(risk_pct or 0.0)
-        return value / 100.0 if value >= 1 else value
+        # Convention across this codebase (Pydantic defaults, API payloads, etc.) is that
+        # risk_pct is ALWAYS expressed as a percentage number, e.g. 1 means "risk 1% of
+        # capital", 0.5 means "risk 0.5% of capital". The previous implementation
+        # (`value / 100.0 if value >= 1 else value`) silently treated any value below 1 as
+        # already being a fraction -- so risk_pct=0.5 (intended: risk half a percent) was
+        # read as 0.5 = 50% of capital, a 100x overshoot that could blow up an account on a
+        # single trade. There is no evidence anywhere in the codebase of callers passing an
+        # already-scaled fraction (e.g. 0.01 for 1%), so always dividing by 100 is the
+        # convention-consistent, safe behavior.
+        value = max(0.0, float(risk_pct or 0.0))
+        fraction = value / 100.0
+        return min(fraction, MAX_RISK_FRACTION_PER_TRADE)
 
     def position_size(self, capital: float, risk_pct: float, entry: float, stop_loss: float) -> int:
         risk_per_unit = abs(float(entry) - float(stop_loss))
@@ -17,9 +33,17 @@
 
         risk_amount = max(0.0, float(capital)) * self.risk_fraction(risk_pct)
         if risk_amount <= 0:
-            return 1
+            return 0
 
-        return max(1, floor(risk_amount / risk_per_unit))
+        # NOTE: this used to be `max(1, floor(risk_amount / risk_per_unit))`, which forced a
+        # minimum of 1 unit even when the risk math says the position should be skipped
+        # entirely (e.g. a wide stop distance relative to a small risk budget). Forcing a
+        # trade in that case silently overrides the caller's risk limit -- 1 unit at that
+        # stop distance can risk many times more than intended. Returning 0 here signals
+        # "this trade doesn't fit within the requested risk budget," and callers (risk_gate,
+        # order_management) already reject non-positive quantities rather than trading with
+        # an unbounded risk override.
+        return floor(risk_amount / risk_per_unit)
 
     def validate_signal(self, signal: StrategySignal) -> bool:
         if signal.entry_price <= 0 or signal.stop_loss <= 0 or signal.target_price <= 0:
